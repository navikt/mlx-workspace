#!/usr/bin/env python3
# mise description="Create venv, install dependencies, bootstrap default model on first run"
"""One-time setup + idempotent dependency install.

Model bootstrap (mise run model-use qwen3.5-9b) only runs when no profile
is active yet — i.e. mise.local.toml has no MLX_ACTIVE_PROFILE.
After first setup, switching models with 'mise run model-use' is permanent
and setup will never override it.
"""
import subprocess
import sys
import tomllib
from pathlib import Path

root = Path(__file__).resolve().parents[2]

# Always: ensure venv and deps are up to date
subprocess.run([sys.executable, "-m", "venv", ".venv"], cwd=root, check=True)
pip = root / ".venv" / "bin" / "pip"
subprocess.run([pip, "install", "--upgrade", "pip", "mlx", "mlx-lm", "mlx-vlm"], cwd=root, check=True)
subprocess.run(
    ["pipx", "install", "aider-chat", "--python", "python3.12"],
    cwd=root,
)  # ok to fail if already installed
subprocess.run(["pipx", "upgrade", "aider-chat"], cwd=root)

# Bootstrap default model only on first run (no active profile yet)
local_toml = root / "mise.local.toml"
active = None
if local_toml.exists():
    try:
        active = tomllib.loads(local_toml.read_text()).get("env", {}).get("MLX_ACTIVE_PROFILE")
    except Exception:
        pass

if not active:
    print("\n→ No active profile found — bootstrapping default: qwen3.5-9b")
    subprocess.run(["mise", "run", "model-use", "qwen3.5-9b"], cwd=root, check=True)
else:
    print(f"\n✓ Active profile already set: {active} — skipping bootstrap")
