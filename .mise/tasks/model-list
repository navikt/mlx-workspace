#!/usr/bin/env python3
# mise description="List model profiles (active, status, download state)"
"""Print a table of all available model profiles."""
import os
import sys

sys.path.insert(0, os.path.dirname(__file__))
import _profiles as P

STATUS_ICON = {
    "recommended":  "⭐",
    "untested":     "🔲",
    "testing":      "🔬",
    "slow":         "🐢",
    "oom":          "💥",
    "skipped":      "⬛",
    "broken":       "🔴",
    "failed":       "❌",
}

SPEC_ICON = {
    "local":     "✓",   # ran on this machine
    "research":  "🔍",  # verified via official docs / HF model cards / web search
    "community": "💬",  # community reports, lower confidence
}

active = P.active_key()
keys = P.list_keys()
if not keys:
    print("No profiles found in profiles/. Add a .toml file first.")
    sys.exit(0)

rows = []
for k in keys:
    meta, params = P.load(k)
    dl      = "✓" if P.is_downloaded(params["MLX_MODEL"]) else "–"
    vram_gb = meta.get("model_vram_gb", 999)
    vram    = f"{vram_gb} GB" if vram_gb != 999 else "?"
    icon    = STATUS_ICON.get(meta["status"], "  ")
    spec    = SPEC_ICON.get(meta.get("spec_source", ""), "?")
    released = meta.get("released", "?")
    marker  = "●" if k == active else " "
    rows.append((marker, k, meta["name"], icon, meta["status"], vram, vram_gb, spec, released, dl))

# Sort: active model first, then by VRAM ascending
rows.sort(key=lambda r: (0 if r[0] == "●" else 1, r[6]))

# Column widths
w_key    = max(len(r[1]) for r in rows)
w_name   = max(len(r[2]) for r in rows)
w_status = max(len(r[4]) for r in rows)

header = (
    f"  {'KEY':<{w_key}}  {'MODEL':<{w_name}}  {'RELEASED'}  {'STATUS':<{w_status+2}}  {'VRAM':>6}  SPECS  DL"
)
print()
print(header)
print("  " + "-" * (len(header) - 2))
for marker, key, name, icon, status, vram, vram_gb, spec, released, dl in rows:
    status_col = f"{icon} {status}"
    print(f"{marker} {key:<{w_key}}  {name:<{w_name}}  {released}  {status_col:<{w_status+2}}  {vram:>6}   {spec}    {dl}")
print()
print("  sorted by VRAM ascending  |  SPECS: ✓=locally tested  🔍=externally verified  💬=community reports  ?=unknown")
print()
