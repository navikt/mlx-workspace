#!/usr/bin/env python3
# mise description="List model profiles (active, status, download state)"
"""Print a table of all available model profiles."""
import os
import sys

sys.path.insert(0, os.path.dirname(__file__))
import _profiles as P

STATUS_ICON = {
    "daily-driver": "⭐",
    "testing":      "🔬",
    "slow":         "🐢",
    "oom":          "💥",
    "skipped":      "⬛",
}

active = P.active_key()
keys = P.list_keys()
if not keys:
    print("No profiles found in profiles/. Add a .toml file first.")
    sys.exit(0)

rows = []
for k in keys:
    meta, params = P.load(k)
    dl = "✓" if P.is_downloaded(params["MLX_MODEL"]) else "–"
    vram = f"{meta['model_vram_gb']} GB" if "model_vram_gb" in meta else "?"
    icon = STATUS_ICON.get(meta["status"], "  ")
    marker = "●" if k == active else " "
    rows.append((marker, k, meta["name"], icon, meta["status"], vram, dl))

# Column widths
w_key    = max(len(r[1]) for r in rows)
w_name   = max(len(r[2]) for r in rows)
w_status = max(len(r[4]) for r in rows)

header = (
    f"  {'KEY':<{w_key}}  {'MODEL':<{w_name}}  {'STATUS':<{w_status+2}}  {'VRAM':>6}  DL"
)
print()
print(header)
print("  " + "-" * (len(header) - 2))
for marker, key, name, icon, status, vram, dl in rows:
    status_col = f"{icon} {status}"
    print(f"{marker} {key:<{w_key}}  {name:<{w_name}}  {status_col:<{w_status+2}}  {vram:>6}  {dl}")
print()
