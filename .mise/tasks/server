#!/usr/bin/env python3
# mise description="Start the OpenAI-compatible HTTP server on port 8080"
"""Dispatch to mlx_lm.server or mlx_vlm.server based on MLX_SERVER_TYPE.

mlx-lm (default): text-only models — Qwen, GLM, Mistral, Granite, etc.
mlx-vlm:          gemma4_unified and other multimodal architectures.

Set MLX_SERVER_TYPE = "mlx-vlm" in the profile [params] to use mlx-vlm.
Set MLX_CHAT_TEMPLATE to a path to override the model's chat template.

Profile params are always re-read from disk at server startup so that
changes to a profile take effect without needing to re-run model-use.
"""
import os
import sys
import tomllib

# ---------------------------------------------------------------------------
# Sync env from the active profile so the server always reflects the current
# profile state, not stale mise.local.toml values from a previous run.
# ---------------------------------------------------------------------------
OPTIONAL_DEFAULTS = {
    "MLX_SERVER_TYPE":       "mlx-lm",
    "MLX_CHAT_TEMPLATE":     "",
    "MLX_TEMP":              "0.6",
    "MLX_CHAT_TEMPLATE_ARGS": "",
}

active_profile = os.environ.get("MLX_ACTIVE_PROFILE", "").strip()
if active_profile:
    workspace = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
    profile_path = os.path.join(workspace, "profiles", f"{active_profile}.toml")
    if os.path.exists(profile_path):
        with open(profile_path, "rb") as f:
            profile = tomllib.load(f)
        params = profile.get("params", {})
        # Apply profile params (override stale mise.local.toml values)
        for key, val in params.items():
            os.environ[key] = str(val)
        # Reset optional vars not set by this profile to their defaults
        for key, default in OPTIONAL_DEFAULTS.items():
            if key not in params:
                os.environ[key] = default
        print(f"✓ Synced params from profiles/{active_profile}.toml")
    else:
        print(f"⚠  Profile not found: profiles/{active_profile}.toml — using env as-is", file=sys.stderr)
else:
    print("⚠  MLX_ACTIVE_PROFILE not set — using env as-is (run 'mise run model-use' to select a profile)", file=sys.stderr)

model         = os.environ["MLX_MODEL"]
max_tokens    = os.environ.get("MLX_MAX_TOKENS", "32768")
cache_bytes   = os.environ.get("MLX_CACHE_BYTES", "")
cache_size    = os.environ.get("MLX_CACHE_SIZE", "")
server_type   = os.environ.get("MLX_SERVER_TYPE", "mlx-lm").strip()
chat_template = os.environ.get("MLX_CHAT_TEMPLATE", "").strip()
# Extra args forwarded to tokenizer's apply_chat_template as JSON, e.g.:
#   '{"enable_thinking": false}'  — disables <think> blocks in GLM/Qwen3 thinking models
chat_template_args = os.environ.get("MLX_CHAT_TEMPLATE_ARGS", "").strip()
# Sampling temperature. mlx_lm.server defaults to 0.0 (greedy), which causes
# infinite repetition loops — once a high-probability token pattern starts, greedy
# decoding reinforces it and the model cannot escape. 0.6 is the standard coding
# trade-off: low enough to keep outputs deterministic and structured, high enough
# to break degenerate loops. Observed symptom at temp=0.0: 'node:util: JSON.stringify
# (9;' repeated endlessly during GLM-4.7-Flash evaluation (2026-06-19).
# Override per-model via MLX_TEMP in [params] if a model needs different behaviour.
temp          = os.environ.get("MLX_TEMP", "0.6").strip()

# Resolve chat_template relative to workspace root if it's a relative path
if chat_template and not os.path.isabs(chat_template):
    workspace = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
    chat_template = os.path.join(workspace, chat_template)

if server_type == "mlx-vlm":
    print(f"→ Starting mlx_vlm.server  (model_type requires mlx-vlm)")
    print(f"  model:      {model}")
    print(f"  max-tokens: {max_tokens}")
    print(f"  Note: mlx-vlm does not support prompt-cache-bytes/size — using default caching")
    print()
    cmd = [
        "python", "-m", "mlx_vlm.server",
        "--model", model,
        "--port", "8080",
        "--max-tokens", max_tokens,
    ]
else:
    print(f"→ Starting mlx_lm.server")
    print(f"  model:       {model}")
    print(f"  max-tokens:  {max_tokens}")
    print(f"  temp:        {temp}")
    print(f"  cache-bytes: {cache_bytes}")
    print(f"  cache-size:  {cache_size}")
    if chat_template:
        print(f"  chat-template: {chat_template}")
    if chat_template_args:
        print(f"  chat-template-args: {chat_template_args}")
    print()
    cmd = [
        "mlx_lm.server",
        "--model", model,
        "--port", "8080",
        "--max-tokens", max_tokens,
        "--temp", temp,
    ]
    if cache_size:
        cmd += ["--prompt-cache-size", cache_size]
    if cache_bytes:
        cmd += ["--prompt-cache-bytes", cache_bytes]
    if chat_template:
        cmd += ["--chat-template", chat_template]
    if chat_template_args:
        cmd += ["--chat-template-args", chat_template_args]

os.execvp(cmd[0], cmd)

max_tokens    = os.environ.get("MLX_MAX_TOKENS", "32768")
cache_bytes   = os.environ.get("MLX_CACHE_BYTES", "")
cache_size    = os.environ.get("MLX_CACHE_SIZE", "")
server_type   = os.environ.get("MLX_SERVER_TYPE", "mlx-lm").strip()
chat_template = os.environ.get("MLX_CHAT_TEMPLATE", "").strip()
# Extra args forwarded to tokenizer's apply_chat_template as JSON, e.g.:
#   '{"enable_thinking": false}'  — disables <think> blocks in GLM/Qwen3 thinking models
chat_template_args = os.environ.get("MLX_CHAT_TEMPLATE_ARGS", "").strip()
# Sampling temperature. mlx_lm.server defaults to 0.0 (greedy), which causes
# infinite repetition loops — once a high-probability token pattern starts, greedy
# decoding reinforces it and the model cannot escape. 0.6 is the standard coding
# trade-off: low enough to keep outputs deterministic and structured, high enough
# to break degenerate loops. Observed symptom at temp=0.0: 'node:util: JSON.stringify
# (9;' repeated endlessly during GLM-4.7-Flash evaluation (2026-06-19).
# Override per-model via MLX_TEMP in [params] if a model needs different behaviour.
temp          = os.environ.get("MLX_TEMP", "0.6").strip()

# Resolve chat_template relative to workspace root if it's a relative path
if chat_template and not os.path.isabs(chat_template):
    workspace = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
    chat_template = os.path.join(workspace, chat_template)

if server_type == "mlx-vlm":
    print(f"→ Starting mlx_vlm.server  (model_type requires mlx-vlm)")
    print(f"  model:      {model}")
    print(f"  max-tokens: {max_tokens}")
    print(f"  Note: mlx-vlm does not support prompt-cache-bytes/size — using default caching")
    print()
    cmd = [
        "python", "-m", "mlx_vlm.server",
        "--model", model,
        "--port", "8080",
        "--max-tokens", max_tokens,
    ]
else:
    print(f"→ Starting mlx_lm.server")
    print(f"  model:       {model}")
    print(f"  max-tokens:  {max_tokens}")
    print(f"  temp:        {temp}")
    print(f"  cache-bytes: {cache_bytes}")
    print(f"  cache-size:  {cache_size}")
    if chat_template:
        print(f"  chat-template: {chat_template}")
    if chat_template_args:
        print(f"  chat-template-args: {chat_template_args}")
    print()
    cmd = [
        "mlx_lm.server",
        "--model", model,
        "--port", "8080",
        "--max-tokens", max_tokens,
        "--temp", temp,
    ]
    if cache_size:
        cmd += ["--prompt-cache-size", cache_size]
    if cache_bytes:
        cmd += ["--prompt-cache-bytes", cache_bytes]
    if chat_template:
        cmd += ["--chat-template", chat_template]
    if chat_template_args:
        cmd += ["--chat-template-args", chat_template_args]

os.execvp(cmd[0], cmd)
