#!/usr/bin/env python3
# mise description="Start the OpenAI-compatible HTTP server on port 8080"
"""Dispatch to mlx_lm.server or mlx_vlm.server based on MLX_SERVER_TYPE.

mlx-lm (default): text-only models — Qwen, GLM, Mistral, Granite, etc.
mlx-vlm:          gemma4_unified and other multimodal architectures.

Set MLX_SERVER_TYPE = "mlx-vlm" in the profile [params] to use mlx-vlm.
"""
import os
import sys

model       = os.environ["MLX_MODEL"]
max_tokens  = os.environ.get("MLX_MAX_TOKENS", "32768")
cache_bytes = os.environ.get("MLX_CACHE_BYTES", "")
cache_size  = os.environ.get("MLX_CACHE_SIZE", "")
server_type = os.environ.get("MLX_SERVER_TYPE", "mlx-lm").strip()

if server_type == "mlx-vlm":
    print(f"→ Starting mlx_vlm.server  (model_type requires mlx-vlm)")
    print(f"  model:      {model}")
    print(f"  max-tokens: {max_tokens}")
    print(f"  Note: mlx-vlm does not support prompt-cache-bytes/size — using default caching")
    print()
    cmd = [
        "python", "-m", "mlx_vlm.server",
        "--model", model,
        "--port", "8080",
        "--max-tokens", max_tokens,
    ]
else:
    print(f"→ Starting mlx_lm.server")
    print(f"  model:       {model}")
    print(f"  max-tokens:  {max_tokens}")
    print(f"  cache-bytes: {cache_bytes}")
    print(f"  cache-size:  {cache_size}")
    print()
    cmd = [
        "mlx_lm.server",
        "--model", model,
        "--port", "8080",
        "--max-tokens", max_tokens,
    ]
    if cache_size:
        cmd += ["--prompt-cache-size", cache_size]
    if cache_bytes:
        cmd += ["--prompt-cache-bytes", cache_bytes]

os.execvp(cmd[0], cmd)
