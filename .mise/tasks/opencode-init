#!/usr/bin/env python3
"""Generate opencode.json from mise env vars."""
import json
import os

model   = os.environ["MLX_MODEL"]

# MLX_OPENCODE_CONTEXT — context window declared to opencode (set in mise.toml).
# Controls when auto-compaction fires: threshold = context − output.
# Intentionally lower than model's real context so each compaction is small and fast.
context = int(os.environ.get("MLX_OPENCODE_CONTEXT", "30000"))

# MLX_OPENCODE_OUTPUT — output token reserve for compaction math (set in mise.toml).
# Separate from MLX_MAX_TOKENS: compaction summaries need ~2-4k tokens, not the full
# generation budget. Smaller reserve = higher effective threshold before compaction fires.
output  = int(os.environ.get("MLX_OPENCODE_OUTPUT", "4096"))

config = {
    "$schema": "https://opencode.ai/config.json",
    # Instruction files opencode loads into every session's system context.
    # AGENTS.md contains project-level rules (e.g. always use rtk for shell commands).
    "instructions": ["AGENTS.md"],
    # RTK plugin: intercepts tool.execute.before and rewrites bash commands
    # to use rtk for token-compressed output. Installed globally via:
    # rtk init -g --opencode → ~/.config/opencode/plugins/rtk.ts
    # Listed here as well so the local config is self-contained.
    "plugin": ["~/.config/opencode/plugins/rtk.ts"],
    "provider": {
        "mlx": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "MLX Local",
            "options": {
                "baseURL": "http://localhost:8080/v1",
                "apiKey": "mlx",
                # Time between SSE chunks before the connection is considered stalled.
                # Raise from 90s: at large context (20k+ tokens) + thinking mode, a single
                # token can take >90s when the KV cache is warm and prompts are long.
                "chunkTimeout": 180000,
                # Total request timeout. Set to False (no timeout) because:
                # - At 25-30k tokens, prompt processing alone can take 2-4 minutes
                # - Thinking mode adds multiple further minutes of generation
                # - A hard timeout causes BrokenPipeError on the server side and
                #   "SSE times out" on the opencode side mid-generation
                # opencode's per-chunk timeout (above) still guards against truly stalled streams.
                "timeout": False,
            },
            "models": {
                model: {
                    "limit": {
                        "context": context,
                        "output": output,
                    }
                }
            },
        }
    },
    "model": f"mlx/{model}",
    # Same model for lightweight tasks (title gen, compaction summaries)
    "small_model": f"mlx/{model}",
}

with open("opencode.json", "w") as f:
    json.dump(config, f, indent=2)
    f.write("\n")

threshold = context - output
print(f"opencode.json written for model: {model}")
print(f"  declared context:  {context:,} tokens  (MLX_OPENCODE_CONTEXT)")
print(f"  output reserve:    {output:,} tokens  (MLX_OPENCODE_OUTPUT)")
print(f"  compaction fires:  ~{threshold:,} tokens")
