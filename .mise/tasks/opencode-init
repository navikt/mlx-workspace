#!/usr/bin/env python3
# mise description="Generate opencode.json. Usage: mise run opencode-init [<output-dir>]"
"""Generate opencode.json from mise env vars.

Optional first argument: directory to write opencode.json into (default: CWD).
Used by 'mise run opencode' to write into samples/<model-key>/.
"""
import json
import os
import sys
from pathlib import Path

# Resolve output directory (default: CWD)
if len(sys.argv) > 1:
    out_dir = Path(sys.argv[1]).resolve()
    out_dir.mkdir(parents=True, exist_ok=True)
else:
    out_dir = Path.cwd()

# AGENTS.md path: absolute so it resolves correctly from any output dir
agents_md = str(Path.cwd() / "AGENTS.md")

model   = os.environ["MLX_MODEL"]

# MLX_OPENCODE_CONTEXT — context window declared to opencode (set in mise.toml).
# Controls when auto-compaction fires: threshold = context − output.
# Intentionally lower than model's real context so each compaction is small and fast.
context       = int(os.environ.get("MLX_OPENCODE_CONTEXT", "131072"))

# MLX_OPENCODE_OUTPUT — output token reserve for compaction math (set in mise.toml).
# Separate from MLX_MAX_TOKENS: compaction summaries need ~2-4k tokens, not the full
# generation budget. Smaller reserve = higher effective threshold before compaction fires.
output        = int(os.environ.get("MLX_OPENCODE_OUTPUT", "4096"))

# MLX_OPENCODE_CHUNK_TIMEOUT — ms between SSE tokens before opencode drops the connection.
# At large context (80k+ tokens) a single token can take minutes on local hardware.
# If this fires mid-generation the model returns an empty response and opencode exits
# the loop silently (observed at 96k tokens: one token took 3min 28s).
chunk_timeout = int(os.environ.get("MLX_OPENCODE_CHUNK_TIMEOUT", "600000"))

config = {
    "$schema": "https://opencode.ai/config.json",
    # Instruction files opencode loads into every session's system context.
    # AGENTS.md contains project-level rules (e.g. always use rtk for shell commands).
    # Absolute path so it resolves correctly whether opencode runs from root or samples/<key>/.
    "instructions": [agents_md],
    # RTK plugin: intercepts tool.execute.before and rewrites bash commands
    # to use rtk for token-compressed output. Installed globally via:
    # rtk init -g --opencode → ~/.config/opencode/plugins/rtk.ts
    # Listed here as well so the local config is self-contained.
    "plugin": ["~/.config/opencode/plugins/rtk.ts"],
    "provider": {
        "mlx": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "MLX Local",
            "options": {
                "baseURL": "http://localhost:8080/v1",
                "apiKey": "mlx",
                # Time between SSE chunks before the connection is considered stalled.
                # At 96k+ tokens, a single token can take >3 minutes on this hardware
                # (observed: chunkTimeout fired at 3min 28s → empty response → loop exit).
                # Set high enough to survive slowest token at max practical context (~100k).
                # Controlled by MLX_OPENCODE_CHUNK_TIMEOUT in mise.toml.
                "chunkTimeout": chunk_timeout,
                # Total request timeout disabled — see chunkTimeout for the real guard.
                "timeout": False,
            },
            "models": {
                model: {
                    "limit": {
                        "context": context,
                        "output": output,
                    }
                }
            },
        }
    },
    "model": f"mlx/{model}",
    # Same model for lightweight tasks (title gen, compaction summaries)
    "small_model": f"mlx/{model}",
}

out_file = out_dir / "opencode.json"
with open(out_file, "w") as f:
    json.dump(config, f, indent=2)
    f.write("\n")

threshold = context - output
print(f"opencode.json written → {out_file}")
print(f"  declared context:  {context:,} tokens  (MLX_OPENCODE_CONTEXT)")
print(f"  output reserve:    {output:,} tokens  (MLX_OPENCODE_OUTPUT)")
print(f"  compaction fires:  ~{threshold:,} tokens")
