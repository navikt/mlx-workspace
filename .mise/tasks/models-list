#!/usr/bin/env python3
"""List downloaded MLX models with their sizes."""
import os
from pathlib import Path

cache_dir = Path.home() / ".cache" / "huggingface" / "hub"

if not cache_dir.exists():
    print("No models found (cache directory does not exist).")
    raise SystemExit(0)

models = sorted(d for d in cache_dir.iterdir() if d.is_dir() and d.name.startswith("models--"))

if not models:
    print("No models downloaded yet.")
    raise SystemExit(0)

total = 0
rows = []
for model_dir in models:
    size = sum(f.stat().st_size for f in model_dir.rglob("*") if f.is_file())
    total += size
    name = model_dir.name.removeprefix("models--").replace("--", "/")
    rows.append((name, size))

name_width = max(len(r[0]) for r in rows)
print(f"\n{'Model':<{name_width}}  Size")
print("-" * (name_width + 12))
for name, size in rows:
    gib = size / (1024 ** 3)
    print(f"{name:<{name_width}}  {gib:.1f} GiB")
print("-" * (name_width + 12))
print(f"{'Total':<{name_width}}  {total / (1024 ** 3):.1f} GiB\n")
